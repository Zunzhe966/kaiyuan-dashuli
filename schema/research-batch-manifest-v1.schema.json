{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kai-yuan-da-shu-li.example/schema/research-batch-manifest-v1.schema.json",
  "title": "Open-source atlas research batch manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "batch_id", "created_at", "input", "counts", "artifact", "rate_limit", "next_since", "failures", "worker"],
  "properties": {
    "schema_version": {"const": "research-batch-manifest-v1"},
    "batch_id": {"$ref": "#/$defs/batchId"},
    "created_at": {"type": "string", "format": "date-time"},
    "input": {"$ref": "#/$defs/input"},
    "counts": {"$ref": "#/$defs/counts"},
    "artifact": {"$ref": "#/$defs/artifact"},
    "rate_limit": {"$ref": "#/$defs/rateLimit"},
    "next_since": {"$ref": "#/$defs/repositoryId"},
    "failures": {"type": "array", "items": {"$ref": "#/$defs/failure"}, "maxItems": 100},
    "worker": {"$ref": "#/$defs/worker"}
  },
  "$defs": {
    "batchId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{5,120}$"},
    "repositoryId": {"type": "string", "pattern": "^[1-9][0-9]*$"},
    "repositoryIds": {"type": "array", "items": {"$ref": "#/$defs/repositoryId"}, "minItems": 1, "maxItems": 100, "uniqueItems": true},
    "input": {
      "type": "object", "additionalProperties": false,
      "required": ["source", "since", "repository_ids", "first_repository_id", "last_repository_id"],
      "properties": {
        "source": {"const": "github-public-repositories"},
        "since": {"type": "string", "pattern": "^[0-9]+$"},
        "repository_ids": {"$ref": "#/$defs/repositoryIds"},
        "first_repository_id": {"$ref": "#/$defs/repositoryId"},
        "last_repository_id": {"$ref": "#/$defs/repositoryId"}
      }
    },
    "counts": {
      "type": "object", "additionalProperties": false,
      "required": ["total", "complete", "unknown", "conflicting", "failed", "skipped"],
      "properties": {
        "total": {"type": "integer", "minimum": 1, "maximum": 100},
        "complete": {"type": "integer", "minimum": 0, "maximum": 100},
        "unknown": {"type": "integer", "minimum": 0, "maximum": 100},
        "conflicting": {"type": "integer", "minimum": 0, "maximum": 100},
        "failed": {"type": "integer", "minimum": 0, "maximum": 100},
        "skipped": {"const": 0}
      }
    },
    "artifact": {
      "type": "object", "additionalProperties": false, "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {"type": "string", "pattern": "^data/quarantine/research/[a-z0-9][a-z0-9-]{5,120}\\.jsonl$"},
        "bytes": {"type": "integer", "minimum": 1, "maximum": 5242880},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "rateLimit": {
      "type": "object", "additionalProperties": false,
      "required": ["resource", "limit", "remaining", "reset_at", "observed_at"],
      "properties": {
        "resource": {"const": "core"},
        "limit": {"type": "integer", "minimum": 0},
        "remaining": {"type": "integer", "minimum": 0},
        "reset_at": {"type": "string", "format": "date-time"},
        "observed_at": {"type": "string", "format": "date-time"}
      }
    },
    "failure": {
      "type": "object", "additionalProperties": false, "required": ["repository_id", "reason", "retry_after", "attempts"],
      "properties": {
        "repository_id": {"$ref": "#/$defs/repositoryId"},
        "reason": {"enum": ["http-error", "http-timeout", "invalid-response", "not-public", "rate-limited", "repository-unavailable", "response-too-large", "unsupported-content"]},
        "retry_after": {"type": ["string", "null"], "format": "date-time"},
        "attempts": {"type": "integer", "minimum": 1}
      }
    },
    "worker": {
      "type": "object", "additionalProperties": false, "required": ["model_role", "program_version", "run_id"],
      "properties": {
        "model_role": {"const": "deepseek-data-worker"},
        "program_version": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,120}$"},
        "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,120}$"}
      }
    }
  }
}
