{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kai-yuan-da-shu-li.example/schema/research-dossier-v1.schema.json",
  "title": "Open-source atlas research dossier v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "batch_id", "record_status", "observed_at", "repository",
    "localized_content", "classification", "technology", "delivery", "platforms",
    "natural_language_support", "licensing", "releases", "lifecycle", "security",
    "quality", "relations", "evidence", "field_states", "worker_notes"
  ],
  "properties": {
    "schema_version": {"const": "research-dossier-v1"},
    "batch_id": {"$ref": "#/$defs/batchId"},
    "record_status": {"enum": ["complete", "unknown", "conflicting"]},
    "observed_at": {"$ref": "#/$defs/dateTime"},
    "repository": {"$ref": "#/$defs/repository"},
    "localized_content": {"$ref": "#/$defs/localizedContent"},
    "classification": {"$ref": "#/$defs/classification"},
    "technology": {"$ref": "#/$defs/technology"},
    "delivery": {"$ref": "#/$defs/delivery"},
    "platforms": {"$ref": "#/$defs/platforms"},
    "natural_language_support": {"$ref": "#/$defs/naturalLanguageSupport"},
    "licensing": {"$ref": "#/$defs/licensing"},
    "releases": {"type": "array", "items": {"$ref": "#/$defs/release"}, "maxItems": 100},
    "lifecycle": {"$ref": "#/$defs/lifecycle"},
    "security": {"$ref": "#/$defs/security"},
    "quality": {"$ref": "#/$defs/quality"},
    "relations": {"type": "array", "items": {"$ref": "#/$defs/relation"}, "maxItems": 200},
    "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}, "minItems": 1, "maxItems": 500},
    "field_states": {
      "type": "object",
      "propertyNames": {"pattern": "^[A-Za-z0-9_-]+(?:\\.[A-Za-z0-9_-]+)*$"},
      "additionalProperties": {"$ref": "#/$defs/fieldState"}
    },
    "worker_notes": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 1000}, "maxItems": 100}
  },
  "$defs": {
    "batchId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{5,120}$"},
    "repositoryId": {"type": "string", "pattern": "^[1-9][0-9]*$"},
    "dateTime": {"type": "string", "format": "date-time"},
    "nullableDateTime": {"oneOf": [{"$ref": "#/$defs/dateTime"}, {"type": "null"}]},
    "stringArray": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 200}, "uniqueItems": true, "maxItems": 100},
    "nullableString": {"type": ["string", "null"], "maxLength": 1000},
    "evidenceIds": {"type": "array", "items": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{1,100}$"}, "uniqueItems": true, "maxItems": 100},
    "nonEmptyEvidenceIds": {"type": "array", "items": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{1,100}$"}, "uniqueItems": true, "minItems": 1, "maxItems": 100},
    "localizedString": {
      "type": "object", "additionalProperties": false, "required": ["zh-CN", "en"],
      "properties": {
        "zh-CN": {"type": "string", "minLength": 1, "maxLength": 2000},
        "en": {"type": "string", "minLength": 1, "maxLength": 2000}
      }
    },
    "localizedList": {
      "type": "object", "additionalProperties": false, "required": ["zh-CN", "en"],
      "properties": {
        "zh-CN": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 1000}, "minItems": 1, "maxItems": 20},
        "en": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 1000}, "minItems": 1, "maxItems": 20}
      }
    },
    "repository": {
      "type": "object", "additionalProperties": false,
      "required": [
        "platform", "platform_repository_id", "platform_node_id", "full_name", "canonical_url", "name_history",
        "default_branch", "default_branch_oid", "visibility", "is_fork", "fork_parent_repository_id",
        "mirror_url", "archived", "disabled", "created_at", "updated_at", "pushed_at"
      ],
      "properties": {
        "platform": {"const": "github"},
        "platform_repository_id": {"$ref": "#/$defs/repositoryId"},
        "platform_node_id": {"type": ["string", "null"], "minLength": 1, "maxLength": 200},
        "full_name": {"type": "string", "pattern": "^[^/\\s]+/[^/\\s]+$", "maxLength": 300},
        "canonical_url": {"type": "string", "format": "uri", "pattern": "^https://github\\.com/[^/]+/[^/]+/?$", "maxLength": 1000},
        "name_history": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["full_name", "canonical_url", "observed_until", "evidence_ids"],
            "properties": {
              "full_name": {"type": "string", "pattern": "^[^/\\s]+/[^/\\s]+$", "maxLength": 300},
              "canonical_url": {"type": "string", "format": "uri", "pattern": "^https://github\\.com/[^/]+/[^/]+/?$", "maxLength": 1000},
              "observed_until": {"$ref": "#/$defs/dateTime"},
              "evidence_ids": {"$ref": "#/$defs/nonEmptyEvidenceIds"}
            }
          },
          "maxItems": 100
        },
        "default_branch": {"type": ["string", "null"], "minLength": 1, "maxLength": 255},
        "default_branch_oid": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
        "visibility": {"const": "public"},
        "is_fork": {"type": "boolean"},
        "fork_parent_repository_id": {"oneOf": [{"$ref": "#/$defs/repositoryId"}, {"type": "null"}]},
        "mirror_url": {"oneOf": [{"type": "string", "format": "uri", "maxLength": 1000}, {"type": "null"}]},
        "archived": {"type": "boolean"},
        "disabled": {"type": "boolean"},
        "created_at": {"$ref": "#/$defs/nullableDateTime"},
        "updated_at": {"$ref": "#/$defs/nullableDateTime"},
        "pushed_at": {"$ref": "#/$defs/nullableDateTime"}
      }
    },
    "localizedContent": {
      "type": "object", "additionalProperties": false, "required": ["name", "summary", "use_when", "avoid_when"],
      "properties": {
        "name": {"$ref": "#/$defs/localizedString"},
        "summary": {"$ref": "#/$defs/localizedString"},
        "use_when": {"$ref": "#/$defs/localizedList"},
        "avoid_when": {"$ref": "#/$defs/localizedList"}
      }
    },
    "classification": {
      "type": "object", "additionalProperties": false,
      "required": ["domain_ids", "subdomain_ids", "task_ids", "capability_ids", "project_types"],
      "properties": {
        "domain_ids": {"$ref": "#/$defs/stringArray"},
        "subdomain_ids": {"$ref": "#/$defs/stringArray"},
        "task_ids": {"$ref": "#/$defs/stringArray"},
        "capability_ids": {"$ref": "#/$defs/stringArray"},
        "project_types": {"$ref": "#/$defs/stringArray"}
      }
    },
    "technology": {
      "type": "object", "additionalProperties": false,
      "required": ["programming_languages", "frameworks", "runtimes", "protocols", "data_types"],
      "properties": {
        "programming_languages": {"$ref": "#/$defs/stringArray"},
        "frameworks": {"$ref": "#/$defs/stringArray"},
        "runtimes": {"$ref": "#/$defs/stringArray"},
        "protocols": {"$ref": "#/$defs/stringArray"},
        "data_types": {"$ref": "#/$defs/stringArray"}
      }
    },
    "delivery": {
      "type": "object", "additionalProperties": false, "required": ["modes", "package_formats", "orchestrators"],
      "properties": {
        "modes": {"$ref": "#/$defs/stringArray"},
        "package_formats": {"$ref": "#/$defs/stringArray"},
        "orchestrators": {"$ref": "#/$defs/stringArray"}
      }
    },
    "platforms": {
      "type": "object", "additionalProperties": false,
      "required": ["operating_systems", "execution_targets", "cpu_architectures", "accelerators"],
      "properties": {
        "operating_systems": {"$ref": "#/$defs/stringArray"},
        "execution_targets": {"$ref": "#/$defs/stringArray"},
        "cpu_architectures": {"$ref": "#/$defs/stringArray"},
        "accelerators": {"$ref": "#/$defs/stringArray"}
      }
    },
    "supportLevel": {"enum": ["full", "partial", "none", "unknown"]},
    "languageSupport": {
      "type": "object", "additionalProperties": false, "required": ["ui", "docs", "community"],
      "properties": {"ui": {"$ref": "#/$defs/supportLevel"}, "docs": {"$ref": "#/$defs/supportLevel"}, "community": {"$ref": "#/$defs/supportLevel"}}
    },
    "naturalLanguageSupport": {
      "type": "object", "additionalProperties": false, "required": ["zh-CN", "en"],
      "properties": {"zh-CN": {"$ref": "#/$defs/languageSupport"}, "en": {"$ref": "#/$defs/languageSupport"}}
    },
    "versionRule": {
      "type": "object", "additionalProperties": false, "required": ["version_range", "expression", "evidence_ids"],
      "properties": {
        "version_range": {"$ref": "#/$defs/versionRange"},
        "expression": {"type": "string", "minLength": 1, "maxLength": 500},
        "evidence_ids": {"$ref": "#/$defs/nonEmptyEvidenceIds"}
      }
    },
    "licensing": {
      "type": "object", "additionalProperties": false,
      "required": ["openness", "current_expression", "version_rules", "additional_terms", "obligations_source"],
      "properties": {
        "openness": {"enum": ["open-source", "open-core", "source-available", "no-license", "unknown", "conflicting"]},
        "current_expression": {"type": "string", "minLength": 1, "maxLength": 500},
        "version_rules": {"type": "array", "items": {"$ref": "#/$defs/versionRule"}, "maxItems": 100},
        "additional_terms": {"$ref": "#/$defs/stringArray"},
        "obligations_source": {"const": "not-provided-by-worker"}
      }
    },
    "release": {
      "type": "object", "additionalProperties": false,
      "required": ["version", "channel", "released_at", "support", "evidence_ids"],
      "properties": {
        "version": {"type": "string", "minLength": 1, "maxLength": 200},
        "channel": {"enum": ["stable", "lts", "prerelease", "nightly", "unknown"]},
        "released_at": {"$ref": "#/$defs/nullableDateTime"},
        "support": {"enum": ["supported", "security-only", "eol", "unknown"]},
        "evidence_ids": {"$ref": "#/$defs/nonEmptyEvidenceIds"}
      }
    },
    "lifecycle": {
      "type": "object", "additionalProperties": false, "required": ["status", "latest_activity_at", "maintenance_model"],
      "properties": {
        "status": {"enum": ["active", "maintenance", "inactive", "archived", "unknown", "conflicting"]},
        "latest_activity_at": {"$ref": "#/$defs/nullableDateTime"},
        "maintenance_model": {"type": "string", "minLength": 1, "maxLength": 200}
      }
    },
    "security": {
      "type": "object", "additionalProperties": false, "required": ["security_policy", "advisory_source", "supported_versions_known"],
      "properties": {
        "security_policy": {"enum": ["present", "absent", "unknown"]},
        "advisory_source": {"type": ["string", "null"], "maxLength": 200},
        "supported_versions_known": {"type": "boolean"}
      }
    },
    "quality": {
      "type": "object", "additionalProperties": false, "required": ["maturity", "production_claim", "known_limitations"],
      "properties": {
        "maturity": {"enum": ["experimental", "early", "stable", "mature", "unknown"]},
        "production_claim": {"type": "string", "minLength": 1, "maxLength": 200},
        "known_limitations": {"$ref": "#/$defs/stringArray"}
      }
    },
    "relation": {
      "type": "object", "additionalProperties": false, "required": ["type", "target_repository_id", "evidence_ids"],
      "properties": {
        "type": {"enum": ["alternative_to", "depends_on", "integrates_with", "supersedes", "same_ecosystem", "parent_category", "fork_of", "mirror_of", "component_of"]},
        "target_repository_id": {"$ref": "#/$defs/repositoryId"},
        "evidence_ids": {"$ref": "#/$defs/nonEmptyEvidenceIds"}
      }
    },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "url", "source_type", "retrieved_at", "applies_to", "version_range", "fact", "content_sha256"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{1,100}$"},
        "url": {"type": "string", "format": "uri", "pattern": "^https://", "maxLength": 2000},
        "source_type": {"enum": ["repository_api", "repository_commit", "readme", "license_file", "notice_file", "release", "documentation", "security_policy", "advisory", "maintainer_announcement"]},
        "retrieved_at": {"$ref": "#/$defs/dateTime"},
        "applies_to": {"type": "array", "items": {"type": "string", "minLength": 3, "maxLength": 300}, "uniqueItems": true, "minItems": 1, "maxItems": 200},
        "version_range": {"oneOf": [{"$ref": "#/$defs/versionRange"}, {"type": "null"}]},
        "fact": {"type": "string", "minLength": 1, "maxLength": 4000},
        "content_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "versionRange": {
      "type": "string",
      "pattern": "^(?:\\*|[0-9]+\\.[0-9]+\\.[0-9]+|(?:>=|>|<=|<|=)[0-9]+\\.[0-9]+\\.[0-9]+(?: (?:>=|>|<=|<|=)[0-9]+\\.[0-9]+\\.[0-9]+)*)$",
      "maxLength": 200
    },
    "fieldState": {
      "type": "object", "additionalProperties": false, "required": ["state", "evidence_ids"],
      "properties": {
        "state": {"enum": ["verified", "inferred", "unknown", "conflicting", "stale"]},
        "evidence_ids": {"$ref": "#/$defs/evidenceIds"}
      }
    }
  }
}
